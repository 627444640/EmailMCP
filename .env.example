# Email MCP development fallback
#
# Desktop users should normally configure values in the GUI. SMTP/IMAP
# authorization codes are stored in the OS credential store and should not be
# written here. This file is only for local Go development or emergency direct
# sidecar runs.

# ===== Shared mailbox account for direct Go runs =====
EMAIL_COMMON_USERNAME=your-email@qq.com
EMAIL_COMMON_PASSWORD=your-auth-code

# ===== SMTP sending =====
EMAIL_SMTP_HOST=smtp.qq.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_SSL=true
EMAIL_SMTP_FROM=your-email@qq.com

# ===== IMAP reading =====
EMAIL_IMAP_HOST=imap.qq.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_SSL=true

# ===== Local attachment boundaries =====
# Downloads from downloadEmailAttachments are written under this directory.
EMAIL_MCP_ATTACHMENT_DOWNLOAD_DIR=attachments

# sendEmail can attach files only from these comma-separated directories.
EMAIL_MCP_ALLOWED_ATTACHMENT_DIRS=outbox,attachments

# Common server presets:
# QQ Mail:    SMTP smtp.qq.com:465    IMAP imap.qq.com:993
# 163 Mail:   SMTP smtp.163.com:465   IMAP imap.163.com:993
# Gmail:      SMTP smtp.gmail.com:465 IMAP imap.gmail.com:993
# Outlook:    SMTP smtp.office365.com:587 with EMAIL_SMTP_SSL=false,
#             IMAP outlook.office365.com:993
